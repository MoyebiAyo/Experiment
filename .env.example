# Firebase web app config for Vercel (and local `npm run build`).
# Copy to .env.local for local builds, or set in Vercel → Settings → Environment Variables.
# Get values: Firebase Console → Project settings → Your apps → Web app
# Or run: npm run firebase:print-env

FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
